// Thunder Ring / LightningRing — tunable parameters.
// Hot-reload enabled: edit while the game is running to balance in real time.
//
// Parameters:
// - damage_by_level: Damage per lightning strike, one entry per level (Lv1..Lv8)
// - count_by_level:  Number of simultaneous strikes per activation,
//                    one entry per level (Lv1..Lv8)
//                    Lv1-2: 1 strike, Lv3-4: 2 strikes, Lv5-7: 3 strikes, Lv8: 4 strikes
// - effect_duration: Duration of the lightning flash visual in seconds
// - visual_size:     Side length of the square flash sprite in pixels
// - visual_color:    RGBA color of the flash sprite ((R, G, B, A) tuple, values in [0.0, 1.0])
// - strike_z:        Z-depth of the strike sprite (higher = drawn on top)
// - target_range:    Max distance from player (px) for enemy targeting; approximates screen radius

ThunderRingConfig(
    damage_by_level: [40.0, 50.0, 60.0, 60.0, 70.0, 80.0, 90.0, 100.0],
    count_by_level:  [1,    1,    2,    2,    3,    3,    3,    4],
    effect_duration: 0.2,
    visual_size:     24.0,
    visual_color:    (0.9, 1.0, 0.2, 0.85),
    strike_z:        6.0,
    target_range:    800.0,
)
