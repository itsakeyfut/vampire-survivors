// Knife / ThousandEdge — tunable parameters.
// Hot-reload enabled: edit while the game is running to balance in real time.
//
// Parameters:
// - base_speed:            Projectile speed at level 1 (pixels per second)
// - speed_per_two_levels:  Speed increase per floor(level/2) step
// - base_damage:           Damage dealt at level 1
// - damage_per_two_levels: Damage increase per floor((level-1)/2) step
// - lifetime:              Projectile lifetime in seconds
// - collider_radius:       Projectile collider radius in pixels
// - spread_angle_deg:      Angle between adjacent knives in a fan (degrees)
// - count_by_level:        Projectiles fired per activation, one entry per level (Lv1..Lv8)

KnifeConfig(
    base_speed:            600.0,
    speed_per_two_levels:  100.0,
    base_damage:           15.0,
    damage_per_two_levels: 5.0,
    lifetime:              5.0,
    collider_radius:       6.0,
    spread_angle_deg:      15.0,
    count_by_level:        [1, 1, 2, 2, 3, 3, 4, 5],
)
