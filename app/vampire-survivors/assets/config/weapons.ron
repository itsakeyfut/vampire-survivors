// Weapon tunable parameters — edit while the game is running for live balance tweaking.
//
// Parameters:
// - whip_range:                   Half-width of the whip hit arc in pixels
// - whip_base_damage:             Damage dealt at level 1
// - whip_damage_per_level:        Extra damage added per level beyond 1
// - whip_effect_duration:         Lifetime (seconds) of the whip hit visual
// - whip_spread_factor:           Vertical spread of the whip fan (0.0–1.0)
// - magic_wand_speed:             Projectile travel speed in pixels per second
// - magic_wand_base_damage:       Damage dealt at level 1
// - magic_wand_damage_per_level:  Extra damage added per level beyond 1
// - magic_wand_lifetime:          Projectile lifetime in seconds
// - magic_wand_collider_radius:   Projectile collider radius in pixels

WeaponConfig(
    // ----- Whip / BloodyTear -----
    whip_range:                  160.0,
    whip_base_damage:            20.0,
    whip_damage_per_level:       10.0,
    whip_effect_duration:        0.15,
    whip_spread_factor:          0.6,

    // ----- Magic Wand / HolyWand -----
    magic_wand_speed:            600.0,
    magic_wand_base_damage:      20.0,
    magic_wand_damage_per_level: 10.0,
    magic_wand_lifetime:         5.0,
    magic_wand_collider_radius:  8.0,
)
