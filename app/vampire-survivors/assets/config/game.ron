// Game rules configuration — limits, timing, XP, camera, and world settings.
// Loaded at startup; hot-reload applies to newly spawned entities.
//
// Parameters:
// - window_width:               Viewport width in pixels
// - window_height:              Viewport height in pixels
// - max_weapons:                Maximum number of weapons the player can carry
// - max_passives:               Maximum number of passive items the player can carry
// - max_weapon_level:           Maximum upgrade level for weapons
// - max_passive_level:          Maximum upgrade level for passive items
// - boss_spawn_time:            Time (seconds) at which the boss spawns
// - treasure_spawn_interval:    Time (seconds) between treasure chest spawns
// - treasure_radius:            Collision radius of a chest in pixels
// - treasure_gold_reward:       Gold awarded when opening a chest that cannot evolve a weapon
// - xp_level_base:              XP required to reach level 2 (scales each level)
// - xp_level_multiplier:        Multiplier applied to XP threshold each level
// - level_up_choice_count:      Number of upgrade cards shown on level-up
// - camera_lerp_speed:          Camera follow smoothing factor (higher = faster)
// - spatial_grid_cell_size:     Cell size (px) for the spatial partitioning grid
// - base_projectile_speed:      Default projectile travel speed in pixels per second
// - base_projectile_lifetime:   Default projectile lifetime in seconds

GameConfig(
    // Window / viewport
    window_width:             1280,
    window_height:            720,
    // Inventory caps
    max_weapons:              6,
    max_passives:             6,
    max_weapon_level:         8,
    max_passive_level:        5,
    // Game rules
    boss_spawn_time:          1800.0,  // 30 minutes in seconds
    treasure_spawn_interval:  180.0,   // 3 minutes in seconds
    treasure_radius:          20.0,    // collision radius of a chest in pixels
    treasure_gold_reward:     50,      // gold awarded when no weapon can evolve
    // XP / levelling
    xp_level_base:               20,
    xp_level_multiplier:         1.2,
    level_up_choice_count:       3,
    luck_bonus_choice_threshold: 1.5,  // 5× Clover (base 1.0 + 5×0.10) unlocks 4th card
    // Camera
    camera_lerp_speed:        10.0,
    // Spatial partitioning
    spatial_grid_cell_size:   64.0,
    // Projectile defaults
    base_projectile_speed:    300.0,
    base_projectile_lifetime: 5.0,
    // Boss Phase2 behavior
    boss_phase2_hp_threshold:      0.6,   // Phase1 → Phase2 at HP ≤ 60%
    boss_phase3_hp_threshold:      0.3,   // Phase2 → Phase3 at HP ≤ 30%
    boss_phase2_speed_multiplier:  1.5,   // Phase2 move speed = base × 1.5
    mini_death_spawn_count:        3,     // Mini Deaths spawned at Phase2 transition
    mini_death_spawn_radius:       80.0,  // Radial offset from boss center (pixels)
    // Boss Phase3 behavior
    boss_phase3_speed_multiplier:  2.0,   // Phase3 move speed = base × 2.0
    mini_death_spawn_count_phase3: 5,     // Mini Deaths spawned at Phase3 transition
    boss_scythe_interval:          3.0,   // Seconds between scythe shots
    boss_scythe_speed:             250.0, // Scythe travel speed (pixels/second)
    boss_scythe_lifetime:          8.0,   // Scythe lifetime before despawn (seconds)
    boss_scythe_damage:            80.0,  // Damage dealt on scythe hit
    boss_scythe_radius:            15.0,  // Scythe collider radius (pixels)
)
